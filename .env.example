# Copy to .env and fill in. NEVER commit your real .env (it is gitignored).
# This file contains NO secrets - only placeholders and public addresses.

# RPC endpoint for the target network (e.g. Sepolia via Alchemy/Infura/your node).
RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Etherscan API key for contract verification (--verify).
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Treasury / admin address that receives the full 100,000,000 CON at deploy.
# Public on-chain address (locked 2026-06-24), not a secret.
TREASURY_ADDRESS=0x46bca9FCf2f372e76D9aE265Da725B222F5ac2e0

# Deployment signing is provided at runtime via your own wallet, e.g.:
#   --ledger / --trezor (hardware wallet, recommended), or
#   --interactive (paste key at prompt), or
#   --account <keystore> (encrypted local keystore).
# Do NOT put a raw private key in this repo or in .env.
